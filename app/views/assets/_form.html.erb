<%= form_with(model: asset) do |form| %>
  <% if asset.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(asset.errors.count, "chyba") %> zabránila uložení majetku:</h2>
      <ul>
        <% asset.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Název*" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :code, "Kód*" %>
    <%= form.text_field :code %>
  </div>

  <div>
    <%= form.label :room_id, "Místnost*" %>
    <%# Místo text_field použijeme výběr ze všech existujících místností %>
    <%= form.collection_select :room_id, Room.all, :id, :name, prompt: "Vyberte místnost" %>
  </div>

  <div>
    <%= form.label :purchase_date, "Datum nákupu*" %>
    <%= form.date_field :purchase_date %>
  </div>

  <div>
    <%= form.label :last_inspection_date, "Datum poslední kontroly*" %>
    <%= form.date_field :last_inspection_date %>
  </div>

  <div>
    <%= form.label :note, "Poznámka" %>
    <%# OPRAVA: text_area místo textarea %>
    <%= form.text_area :note %>
  </div>

  <div>
    <%= form.label :purchase_price, "Cena nákupu" %>
    <%= form.text_field :purchase_price %>
  </div>

  <div style="margin-bottom: 15px; border: 1px solid #ddd; padding: 15px; border-radius: 5px; background: #f9f9f9;">
    <%= form.label :attachments, "Přílohy majetku (faktury, návody, fotky)", style: "display: block; font-weight: bold;" %>
    <p style="font-size: 0.8em; color: #666;">Můžete vybrat více souborů najednou.</p>
    <%= form.file_field :attachments, multiple: true, style: "margin-top: 5px;" %>
  </div>

  <div style="margin-top: 20px;">
    <%= form.submit "Uložit majetek" %>
  </div>
<% end %>