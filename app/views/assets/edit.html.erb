<% content_for :title, "Upravit majetek: #{@asset.name} | PropertyManager" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">

      <%# Breadcrumbs %>
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Majetek", assets_path, class: "text-decoration-none" %></li>
          <li class="breadcrumb-item"><%= link_to @asset.name, @asset, class: "text-decoration-none" %></li>
          <li class="breadcrumb-item active" aria-current="page">Upravit</li>
        </ol>
      </nav>

      <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <%# Header s ikonkou tužky a žlutým nádechem %>
        <div class="card-header bg-white py-4 border-bottom-0">
          <div class="d-flex align-items-center">
            <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3 text-warning d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
              <i class="bi bi-pencil-square fs-4"></i>
            </div>
            <div>
              <h1 class="h4 mb-0 fw-bold">Upravit záznam majetku</h1>
              <p class="text-muted small mb-0">Aktualizace parametrů pro: <strong class="text-dark"><%= @asset.name %></strong></p>
            </div>
          </div>
        </div>

        <div class="card-body px-4 pt-2 pb-4">
          <hr class="mt-0 mb-4 opacity-10">

          <%# Použijeme ten stejný nabitý partial jako v New %>
          <%= render "form", asset: @asset %>
        </div>

        <%# Footer s užitečnými odkazy %>
        <div class="card-footer bg-light border-top-0 py-3 d-flex justify-content-between align-items-center px-4">
          <%= link_to assets_path, class: "btn btn-link btn-sm text-decoration-none text-muted p-0" do %>
            <i class="bi bi-arrow-left me-1"></i> Zpět na seznam
          <% end %>

          <%= link_to @asset, class: "btn btn-link btn-sm text-decoration-none p-0" do %>
            <i class="bi bi-eye me-1"></i> Zobrazit detail karty
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>