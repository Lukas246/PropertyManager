<% content_for :title, "Evidence majetku" %>

<div class="container-fluid py-4">

  <%# Flash zprávy %>
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zavřít"></button>
    </div>
  <% end %>

  <%# Hlavička stránky %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">📦 Evidence majetku</h1>
    <% if can? :create, Asset %>
      <%= link_to "Přidat nový majetek", new_asset_path, class: "btn btn-primary shadow-sm" %>
    <% end %>
  </div>

  <%# Filtrační panel %>
  <div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
      <h5 class="card-title text-secondary mb-3 fs-6 text-uppercase fw-bold">
        <i class="bi bi-funnel me-2"></i>Filtrování dat
      </h5>

      <%= form_with url: assets_path, method: :get, local: true do |f| %>
        <%# row g-3 zajistí responzivní mřížku pro filtry %>
        <div class="row g-3">

          <div class="col-md-4 col-lg-2">
            <%= f.label :query, "Hledat (název, kód)", class: "form-label small fw-bold" %>
            <%= f.text_field :query, value: params[:query], placeholder: "Zadejte text...", class: "form-control" %>
          </div>

          <div class="col-md-4 col-lg-2">
            <%= f.label :room_id, "Místnost", class: "form-label small fw-bold" %>
            <%= f.collection_select :room_id, Room.all, :id, :name, { include_blank: "Všechny místnosti", selected: params[:room_id] }, { class: "form-select" } %>
          </div>

          <div class="col-md-4 col-lg-2">
            <%= f.label :purchase_date_from, "Nakoupeno od", class: "form-label small fw-bold" %>
            <%= f.date_field :purchase_date_from, value: params[:purchase_date_from], class: "form-control" %>
          </div>

          <div class="col-md-4 col-lg-2">
            <%= f.label :purchase_date_to, "Nakoupeno do", class: "form-label small fw-bold" %>
            <%= f.date_field :purchase_date_to, value: params[:purchase_date_to], class: "form-control" %>
          </div>

          <div class="col-md-4 col-lg-2">
            <%= f.label :price_from, "Min. cena (Kč)", class: "form-label small fw-bold" %>
            <%= f.number_field :price_from, value: params[:price_from], placeholder: "Od...", class: "form-control" %>
          </div>

          <div class="col-md-4 col-lg-2">
            <%= f.label :price_to, "Max. cena (Kč)", class: "form-label small fw-bold" %>
            <%= f.number_field :price_to, value: params[:price_to], placeholder: "Do...", class: "form-control" %>
          </div>

        </div>

        <%# Tlačítka filtrů a exportu %>
        <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top align-items-center">
          <%= f.submit "Použít filtry", name: nil, class: "btn btn-primary" %>
          <%= link_to "Zrušit vše", assets_path, class: "btn btn-secondary" %>

          <%# Třída ms-auto automaticky odsune tlačítko exportu úplně doprava %>
          <div class="ms-auto">
            <%= link_to assets_path(request.query_parameters.merge(format: :csv)), class: "btn btn-success" do %>
              <i class="bi bi-file-earmark-spreadsheet me-1"></i> Exportovat CSV
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Tabulka majetku %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">

          <thead class="table-light text-muted">
          <tr>
            <th class="ps-4">Název majetku</th>
            <th>Kód</th>
            <th>Umístění</th>
            <th>Cena</th>
            <th class="text-end pe-4">Akce</th>
          </tr>
          </thead>

          <tbody id="assets_list">
          <% if @assets.any? %>
            <% @assets.each do |asset| %>
              <tr>
                <td class="ps-4 fw-bold text-dark">
                  <%= asset.name %>
                </td>
                <td>
                  <span class="text-secondary font-monospace bg-light px-2 py-1 rounded"><%= asset.code %></span>
                </td>
                <td>
                  <% if asset.room && asset.room.building %>
                    <%= asset.room.building.name %> / <%= asset.room.name %>
                  <% else %>
                    <span class="text-muted fst-italic">Nepřiřazeno</span>
                  <% end %>
                </td>
                <td>
                  <%= number_to_currency(asset.purchase_price, unit: "Kč", format: "%n %u", precision: 0) %>
                </td>
                <td class="text-end pe-4">
                  <div class="d-flex justify-content-end gap-2">
                    <%= link_to "Detail", asset_path(asset), class: "btn btn-sm btn-outline-primary" %>
                    <% if can? :update, asset %>
                      <%= link_to "Upravit", edit_asset_path(asset), class: "btn btn-sm btn-outline-secondary" %>
                    <% end %>

                    <%# Přidal jsem i tlačítko Smazat pro konzistenci s budovami/místnostmi, pokud ho nechcete, stačí řádek smazat %>
                    <% if can? :destroy, asset %>
                      <%= button_to "Smazat", asset, method: :delete, class: "btn btn-sm btn-outline-danger", form: { class: "d-inline", data: { turbo_confirm: "Opravdu chcete majetek '#{asset.name}' smazat?" } } %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <%# Prázdný stav tabulky %>
            <tr>
              <td colspan="5" class="text-center text-muted py-5 border-0">
                <i class="bi bi-box-seam fs-1 d-block mb-2"></i>
                Nenalezen žádný majetek. Zkuste upravit filtry nebo přidejte nový.
              </td>
            </tr>
          <% end %>
          </tbody>

        </table>
      </div>
    </div>
  </div>
</div>