<% content_for :title, "Evidence majetku" %>

<div class="container-fluid py-4">

  <%# Flash zprávy %>
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zavřít"></button>
    </div>
  <% end %>

  <%# Nadpis a hlavní akce %>
  <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h1 class="h3 mb-0 text-dark">📦 Evidence a správa majetku</h1>
    <% if can? :create, Asset %>
      <%= link_to new_asset_path, class: "btn btn-primary shadow-sm" do %>
        <i class="bi bi-plus-lg me-1"></i> Přidat nový majetek
      <% end %>
    <% end %>
  </div>

  <%# Původní form_with nahradíme tímto: %>
  <%= search_form_for @q, url: assets_path, method: :get, local: true do |f| %>
    <div class="row g-3">

      <%# Hledání v názvu NEBO kódu NEBO poznámce (obsahuje text) %>
      <div class="col-md-4 col-lg-3">
        <%= f.label :name_or_code_or_description_cont, "Hledat (název nebo kód)", class: "form-label small fw-bold" %>
        <%= f.search_field :name_or_code_cont, placeholder: "Zadejte text...", class: "form-control" %>
      </div>

      <%# Přesná shoda ID místnosti %>
      <div class="col-md-4 col-lg-2">
        <%= f.label :room_id_eq, "Místnost", class: "form-label small fw-bold" %>
        <%= f.collection_select :room_id_eq, @available_rooms, :id, :name, { include_blank: "Všechny místnosti" }, { class: "form-select" } %>
      </div>

      <%# Datum pořízení OD a DO (Greater Than or Equal, Less Than or Equal) %>
      <div class="col-md-2">
        <%= f.label :purchase_date_gteq, "Nakoupeno od", class: "form-label small fw-bold" %>
        <%= f.date_field :purchase_date_gteq, class: "form-control" %>
      </div>

      <div class="col-md-2">
        <%= f.label :purchase_date_lteq, "Nakoupeno do", class: "form-label small fw-bold" %>
        <%= f.date_field :purchase_date_lteq, class: "form-control" %>
      </div>

      <%# Cena OD a DO (Greater Than or Equal, Less Than or Equal) %>
      <div class="col-md-2">
        <%= f.label :purchase_price_gteq, "Min. cena", class: "form-label small fw-bold" %>
        <%= f.number_field :purchase_price_gteq, placeholder: "Od...", class: "form-control" %>
      </div>

      <div class="col-md-2">
        <%= f.label :purchase_price_lteq, "Max. cena", class: "form-label small fw-bold" %>
        <%= f.number_field :purchase_price_lteq, placeholder: "Do...", class: "form-control" %>
      </div>

    </div>

    <div class="mt-4 pt-3 border-top d-flex flex-wrap gap-2">
      <%= f.submit "Použít filtry", class: "btn btn-primary px-4" %>
      <%= link_to "Zrušit vše", assets_path, class: "btn btn-outline-secondary" %>

      <div class="ms-auto">
        <%= link_to assets_path(request.query_parameters.merge(format: :csv)), class: "btn btn-success" do %>
          <i class="bi bi-file-earmark-spreadsheet me-1"></i> Exportovat CSV
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Tabulka majetku %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light text-muted">
          <tr>
            <%# 1. Název (Zarovnáno vlevo) %>
            <th class="ps-4" style="width: 25%">
              <%= sort_link(@q, :name, "Název majetku") %>
            </th>

            <%# 2. Kód (Na střed) %>
            <th class="text-center">
              <%= sort_link(@q, :code, "Kód") %>
            </th>

            <%# 3. Budova (Na střed) %>
            <th class="text-center">
              <%= sort_link(@q, :room_building_name, "Budova") %>
            </th>

            <%# 4. Místnost (Na střed) %>
            <th class="text-center">
              <%= sort_link(@q, :room_name, "Místnost") %>
            </th>

            <%# 5. Cena (Na střed) %>
            <th class="text-center">
              <%= sort_link(@q, :purchase_price, "Cena") %>
            </th>

            <%# 6. Akce (Doprava) %>
            <th class="text-end pe-4">Akce</th>
          </tr>
          </thead>

          <tbody id="assets">
          <% @assets.each do |asset| %>
            <tr>
              <%# 1. Název %>
              <td class="ps-4 fw-bold text-dark">
                <%= asset.name %>
              </td>

              <%# 2. Kód %>
              <td class="text-center">
                <code class="text-secondary bg-light px-2 py-1 rounded small"><%= asset.code %></code>
              </td>

              <%# 3. Budova %>
              <td class="text-center small text-muted">
                <% if asset.room&.building %>
                  <%= link_to asset.room.building.name, building_path(asset.room.building), class: "text-decoration-none fw-bold" %>
                <% else %>
                  <span class="text-black-25">-</span>
                <% end %>
              </td>

              <%# 4. Místnost %>
              <td class="text-center small text-muted">
                <% if asset.room %>
                  <%= link_to asset.room.name, room_path(asset.room), class: "text-decoration-none text-secondary" %>
                <% else %>
                  <span class="text-black-25">-</span>
                <% end %>
              </td>

              <%# 5. Cena %>
              <td class="text-center fw-bold">
                <%= number_to_currency(asset.purchase_price, unit: "Kč", format: "%n %u", precision: 0) %>
              </td>

              <%# 6. Akce %>
              <td class="text-end pe-4 text-nowrap">
                <div class="d-flex justify-content-end gap-2">
                  <%= link_to asset_path(asset), class: "btn btn-sm btn-outline-primary", title: "Detail" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>

                  <% if can? :update, asset %>
                    <%= link_to edit_asset_path(asset), class: "btn btn-sm btn-outline-secondary", title: "Upravit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                  <% end %>

                  <% if can? :destroy, asset %>
                    <%= button_to asset, method: :delete,
                                  class: "btn btn-sm btn-outline-danger",
                                  form: { class: "d-inline", data: { turbo_confirm: "Opravdu smazat #{asset.name}?" } },
                                  title: "Smazat" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# Patička se stránkováním Kaminari %>
    <% if @assets.respond_to?(:total_pages) %>
      <div class="card-footer bg-white border-top py-3">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
          <div class="text-muted small mb-3 mb-md-0">
            Zobrazeno <strong><%= @assets.offset_value + 1 %></strong> –
            <strong><%= @assets.offset_value + @assets.length %></strong> z
            <strong><%= @assets.total_count %></strong> záznamů
          </div>
          <div class="pagination-sm">
            <%= paginate @assets %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>