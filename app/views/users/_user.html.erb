<div id="<%= dom_id user %>">
  <div>
    <strong>Full name:</strong>
    <%= user.full_name %>
  </div>

  <div>
    <strong>Role:</strong>
    <%= user.role %>
  </div>

  <div>
    <strong>Email:</strong>
    <%= user.email %>
  </div>

  <div>
    <strong>Phone:</strong>
    <%= user.phone %>
  </div>

  <div>
    <strong>Member code:</strong>
    <%= user.member_code %>
  </div>

</div>
