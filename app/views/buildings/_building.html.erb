<%# app/views/buildings/_building.html.erb %>
<div id="<%= dom_id(building) %>">
  <%# Využijeme Bootstrap Grid (row) pro hezčí rozložení informací vedle sebe %>
  <div class="row g-3">

    <div class="col-sm-6 col-md-4">
      <h6 class="text-muted mb-1 small text-uppercase fw-bold">Název budovy</h6>
      <p class="fs-5 mb-0"><%= building.name %></p>
    </div>

    <div class="col-sm-6 col-md-4">
      <h6 class="text-muted mb-1 small text-uppercase fw-bold">Kód objektu</h6>
      <p class="fs-5 mb-0 font-monospace"><%= building.code %></p>
    </div>

    <div class="col-sm-6 col-md-4">
      <h6 class="text-muted mb-1 small text-uppercase fw-bold">Adresa</h6>
      <p class="fs-5 mb-0"><%= building.address.presence || '<span class="text-black-50 fst-italic">Nevyplněno</span>'.html_safe %></p>
    </div>

    <div class="col-sm-6 col-md-4">
      <h6 class="text-muted mb-1 small text-uppercase fw-bold">Kontaktní osoba (E-mail)</h6>
      <p class="mb-0">
        <i class="bi bi-envelope me-1 text-secondary"></i>
        <%= building.contact_person_email %>
      </p>
    </div>

    <div class="col-sm-6 col-md-4">
      <h6 class="text-muted mb-1 small text-uppercase fw-bold">Telefon</h6>
      <p class="mb-0">
        <i class="bi bi-telephone me-1 text-secondary"></i>
        <%= building.contact_person_phone %>
      </p>
    </div>

    <div class="col-sm-6 col-md-4">
      <h6 class="text-muted mb-1 small text-uppercase fw-bold">Datum přidání</h6>
      <p class="mb-0">
        <i class="bi bi-calendar3 me-1 text-secondary"></i>
        <%# Naformátování data na český tvar (např. 03. 04. 2026) %>
        <%= building.building_created_at&.strftime("%d. %m. %Y") %>
      </p>
    </div>

  </div>
</div>