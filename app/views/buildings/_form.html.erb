<%= form_with(model: building) do |form| %>
  <% if building.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(building.errors.count, "error") %> prohibited this building from being saved:</h2>

      <ul>
        <% building.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :code, style: "display: block" %>
    <%= form.text_field :code %>
  </div>

  <div>
    <%= form.label :address, style: "display: block" %>
    <%= form.text_field :address %>
  </div>

  <div>
    <%= form.label :contact_person_email, style: "display: block" %>
    <%= form.text_field :contact_person_email %>
  </div>

  <div>
    <%= form.label :contact_person_phone, style: "display: block" %>
    <%= form.text_field :contact_person_phone %>
  </div>

  <div>
    <%= form.label :building_created_at, style: "display: block" %>
    <%= form.date_field :building_created_at %>
  </div>

  <div style="margin-bottom: 20px; border: 1px solid #ddd; padding: 15px; border-radius: 5px;">
    <strong>Přiřazení správců:</strong>
    <p style="font-size: 0.8em; color: #666;">Vyberte uživatele s rolí správce, kteří mají k této budově přístup.</p>

    <%= form.collection_check_boxes :manager_ids, User.where(role: :spravce), :id, :email do |b| %>
      <div style="display: block;">
        <%= b.check_box %>
        <%= b.label %>
      </div>
    <% end %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
