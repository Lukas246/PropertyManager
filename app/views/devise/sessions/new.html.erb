<div style="max-width: 400px; margin: 50px auto; padding: 20px; border: 1px solid #ddd; border-radius: 8px; font-family: sans-serif;">
  <h2 style="text-align: center;">Přihlášení do systému</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div style="margin-bottom: 15px;">
      <%= f.label :email, style: "display: block; margin-bottom: 5px;" %><br />
      <%= f.email_field :email, autofocus: true, autocomplete: "email", style: "width: 100%; padding: 8px; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :password, "Heslo", style: "display: block; margin-bottom: 5px;" %><br />
      <%= f.password_field :password, autocomplete: "current-password", style: "width: 100%; padding: 8px; box-sizing: border-box;" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div style="margin-bottom: 15px;">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, "Zapamatovat si mě" %>
      </div>
    <% end %>

    <div style="text-align: center;">
      <%= f.submit "Přihlásit se", style: "background-color: #007bff; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; width: 100%;" %>
    </div>
  <% end %>

  <div style="margin-top: 15px; text-align: center;">
    <%= render "devise/shared/links" %>
  </div>
</div>