<div class="container-fluid py-4">

  <%# Flash zprávy %>
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zavřít"></button>
    </div>
  <% end %>

  <%# Hlavička stránky %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Seznam místností</h1>
    <%= link_to "Přidat novou místnost", new_room_path, class: "btn btn-primary shadow-sm" %>
  </div>

  <%# Karta s tabulkou %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">

          <thead class="table-light text-muted">
          <tr>
            <th class="ps-4">Název místnosti</th>
            <th>Kód</th>
            <th>Přiřazená budova</th>
            <th>Přidáno</th>
            <th>Stav</th>
            <th class="text-end pe-4">Akce</th>
          </tr>
          </thead>

          <tbody>
          <% if @rooms.any? %>
            <% @rooms.each do |room| %>
              <tr>
                <td class="ps-4 fw-bold text-dark">
                  <%= room.name %>
                </td>
                <td>
                  <span class="text-secondary font-monospace bg-light px-2 py-1 rounded"><%= room.code %></span>
                </td>
                <td>
                  <%# Pokud místnost patří budově, vypíšeme její jméno a uděláme z něj odkaz na detail budovy %>
                  <% if room.building %>
                    <%= link_to room.building.name, building_path(room.building), class: "text-decoration-none" %>
                  <% else %>
                    <span class="text-muted fst-italic">Bez budovy</span>
                  <% end %>
                </td>
                <td>
                  <%= room.room_created_at&.strftime("%d. %m. %Y") %>
                </td>
                <td>
                  <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Aktivní</span>
                </td>
                <td class="text-end pe-4">

                  <div class="d-flex justify-content-end gap-2">
                    <%= link_to "Detail", room_path(room), class: "btn btn-sm btn-outline-primary" %>
                    <%= link_to "Upravit", edit_room_path(room), class: "btn btn-sm btn-outline-secondary" %>

                    <%= button_to "Smazat", room,
                                  method: :delete,
                                  class: "btn btn-sm btn-outline-danger",
                                  form: {
                                    class: "d-inline",
                                    data: { turbo_confirm: "Opravdu chcete smazat místnost '#{room.name}'?" }
                                  }
                    %>
                  </div>

                </td>
              </tr>
            <% end %>
          <% else %>
            <%# Prázdný stav %>
            <tr>
              <td colspan="6" class="text-center text-muted py-5 border-0">
                <i class="bi bi-door-open fs-1 d-block mb-2"></i>
                Zatím nemáte v systému žádné místnosti.
              </td>
            </tr>
          <% end %>
          </tbody>

        </table>
      </div>
    </div>
  </div>
</div>