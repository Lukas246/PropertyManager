<div class="container-fluid py-4">

  <%# Flash zprávy %>
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zavřít"></button>
    </div>
  <% end %>

  <%# Hlavička stránky %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Seznam místností</h1>
    <%= link_to "Přidat novou místnost", new_room_path, class: "btn btn-primary shadow-sm" %>
  </div>

  <%# Karta s tabulkou %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">

          <thead class="table-light text-muted">
          <tr>
            <th class="ps-4"><%= sort_link(@q, :name, "Název místnosti") %></th>
            <th class="text-center"><%= sort_link(@q, :code, "Kód") %></th>
            <th class="text-center"><%= sort_link(@q, :building_name, "Budova") %></th>
            <th class="text-center">Stav</th>
            <th class="text-center"><%= sort_link(@q, :room_created_at, "Přidáno") %></th>
            <th class="text-center">Akce</th>
          </tr>
          </thead>

          <tbody id="rooms">
          <% if @rooms.any? %>
            <%= render partial: "rooms/room_row", collection: @rooms, as: :room, cached: true %>
          <% else %>
            <tr>
              <td colspan="5" class="text-center py-5 text-muted">Žádné místnosti.</td>
            </tr>
          <% end %>
          </tbody>

        </table>
      </div>
    </div>
  </div>
</div>