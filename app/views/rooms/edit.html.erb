<% content_for :title, "Upravit místnost: #{@room.name} | PropertyManager" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      <%# Breadcrumbs - aby uživatel věděl, kde přesně v hierarchii je %>
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Místnosti", rooms_path, class: "text-decoration-none" %></li>
          <li class="breadcrumb-item"><%= link_to @room.name, @room, class: "text-decoration-none" %></li>
          <li class="breadcrumb-item active" aria-current="page">Upravit</li>
        </ol>
      </nav>

      <%# Karta s formulářem %>
      <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <%# Header s ikonkou tužky %>
        <div class="card-header bg-white py-4 border-bottom-0">
          <div class="d-flex align-items-center">
            <div class="bg-secondary bg-opacity-10 p-3 rounded-circle me-3 text-secondary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
              <i class="bi bi-pencil-square fs-4"></i>
            </div>
            <div>
              <h1 class="h4 mb-0 fw-bold">Upravit místnost</h1>
              <p class="text-muted small mb-0 text-truncate" style="max-width: 250px;">Aktualizace údajů pro: <strong><%= @room.name %></strong></p>
            </div>
          </div>
        </div>

        <div class="card-body px-4 pt-2 pb-4">
          <hr class="mt-0 mb-4 opacity-10">

          <%# Renderujeme ten stejný nabušený partial jako v New %>
          <%= render "form", room: @room %>
        </div>

        <%# Footer s rychlými odkazy %>
        <div class="card-footer bg-light border-top-0 py-3 d-flex justify-content-between align-items-center px-4">
          <%= link_to rooms_path, class: "btn btn-link btn-sm text-decoration-none text-muted p-0" do %>
            <i class="bi bi-arrow-left me-1"></i> Zpět na seznam
          <% end %>

          <%= link_to @room, class: "btn btn-link btn-sm text-decoration-none p-0" do %>
            <i class="bi bi-eye me-1"></i> Zobrazit detail
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>