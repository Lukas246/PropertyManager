<%= form_with(model: room) do |form| %>
  <% if room.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(room.errors.count, "chyba", "chyby", "chyb") %> zabránily uložení místnosti:</h2>
      <ul>
        <% room.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Název místnosti", style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :code, "Kód místnosti", style: "display: block" %>
    <%= form.text_field :code %>
  </div>

  <div>
    <%= form.label :building_id, "Budova", style: "display: block" %>

    <%# KOUZLO S VÝBĚREM BUDOVY %>
    <% if local_assigns[:building] %>
      <%# Jsme na detailu budovy: Zobrazíme jen text a ID pošleme skrytě %>
      <div style="padding: 4px 8px; background-color: #f3f4f6; border: 1px solid #d1d5db; border-radius: 4px; display: inline-block;">
        <strong><%= building.name %></strong>
      </div>
      <%= form.hidden_field :building_id, value: building.id %>
    <% else %>
      <%# Jsme na obecné stránce /rooms/new: Zobrazíme roletku s výběrem %>
      <%= form.collection_select :building_id, Building.accessible_by(current_ability), :id, :name, { prompt: "--- Vyberte budovu ---" } %>
    <% end %>
  </div>

  <div>
    <%= form.label :room_created_at, "Datum vytvoření", style: "display: block" %>
    <%= form.date_field :room_created_at %>
  </div>

  <div style="margin-top: 15px;">
    <%= form.submit "Uložit místnost" %>
  </div>
<% end %>