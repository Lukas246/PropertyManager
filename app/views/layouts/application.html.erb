<!DOCTYPE html>
<html>
<head>
  <title>Property Manager</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <%# 1. Bootstrap CSS (Hlavní styly) %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <%# 2. Bootstrap Icons (Pro ikonky budov, místností, atd.) %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

  <%# 3. Bootstrap JS (Nutné pro zavírání flash zpráv, rozbalovací menu a modální okna) %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body style="font-family: sans-serif; line-height: 1.6; padding: 20px;">

<header style="border-bottom: 2px solid #eee; margin-bottom: 20px; padding-bottom: 10px;">
  <nav>
    <% if user_signed_in? %>
      <div style="float: right;">
        Přihlášen jako: <strong><%= current_user.email %></strong> [<%= current_user.role %>] |
        <%= link_to "Odhlásit", destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: "Opravdu se chcete odhlásit?" }, style: "color: red;" %>
      </div>

      <div style="display: flex; gap: 15px;">
        <%= link_to "🏠 Budovy", buildings_path, data: { turbo: false } %>
        <%= link_to "🚪 Místnosti", rooms_path, data: { turbo: false } %>
        <%= link_to "📦 Majetek", assets_path, data: { turbo: false } %>
        <% if can? :manage, User %>
          <%= link_to "👥 Uživatelé", users_path, data: { turbo: false } %>
        <% end %>
      </div>
    <% else %>
      <strong>Property Manager System</strong>
    <% end %>
  </nav>
</header>

<%# Flash zprávy pro upozornění (úspěch/chyba) %>

<% if alert %>
  <p style="padding: 10px; background: #f8d7da; color: #721c24; border-radius: 5px;"><%= alert %></p>
<% end %>

<main>
  <%= yield %>
</main>

<footer style="margin-top: 50px; border-top: 1px solid #eee; font-size: 0.8em; color: #888;">
  &copy; <%= Time.now.year %> Property Manager - Inventurní systém
</footer>

</body>
</html>